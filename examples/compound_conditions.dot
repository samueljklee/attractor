// Compound Conditions, Context Variables, and ${braced} Expansion
//
// Demonstrates three advanced features of the attractor DOT dialect:
//
//  1. COMPOUND CONDITIONS (&&)
//     Edge conditions support && to require multiple context checks.
//     All clauses must hold for the edge to match.
//
//       condition="outcome = success && tool.verify.output = pass"
//
//  2. DOTTED CONTEXT VARIABLE LOOKUP
//     Conditions reference any key in the pipeline context dict.
//     Per spec §4.10, tool.<id>.output is ONLY set when exit code = 0:
//
//       tool.<id>.output    — set on success only (outcome = success edges)
//       codergen.<id>.output — always set after a box node completes
//
//     If the key is missing, the clause evaluates to false.
//
//  3. ${BRACED} VARIABLE EXPANSION IN PROMPTS
//     Both $var and ${var} work in prompts and tool commands.
//     The braced form is needed when the variable is adjacent to other text:
//
//       "found in ${count}% of cases"  ← ${count} is unambiguous
//       "found in $count% of cases"    ← $count% would look for key "count%"
//
//
// Pipeline:
//   1. LLM writes a Python module (box node) — output in codergen.implement.output
//   2. Tool node compiles + smoke-tests the file (parallelogram)
//      On success (exit 0): prints "pass", sets tool.verify.output = "pass"
//      On failure (exit 1): prints "fail" to stderr, tool.verify.output NOT set
//   3. Compound condition routes to done or fix:
//        done: outcome=success AND tool.verify.output="pass"
//        fix:  outcome=fail → use $codergen.implement.output (always available)
//
// Run: uv run python -m attractor_pipeline.cli run examples/compound_conditions.dot

digraph CompoundConditions {
    graph [
        goal="Write a Python module with a string reversal utility"
        max_goal_gate_redirects="3"
    ]

    start [shape=Mdiamond]

    // ── Step 1: LLM writes the code to a file ───────────────────────────────
    //
    // ${goal} (braced form) is used here to demonstrate that braced and bare
    // forms are equivalent, but braced is safer when adjacent to other text.

    implement [
        shape=box,
        prompt="Goal: ${goal}\n\nWrite a Python module and save it as reverse_str.py.\n\nThe module must export:\n  def reverse_str(s: str) -> str   — returns the string reversed\n  def is_palindrome(s: str) -> bool — returns True if s == reverse_str(s)\n\nNo main block, no tests — just the two functions with docstrings."
    ]

    // ── Step 2: Tool node verifies the written file ──────────────────────────
    //
    // Spec §4.10: tool.<id>.output is ONLY written to context on exit code 0.
    // On failure (exit 1), outcome=fail and no context key is set.
    //
    // This is intentional: the compound condition below checks
    // tool.verify.output on the SUCCESS edge only, where the value IS set.

    verify [
        shape=parallelogram,
        label="Compile + smoke test",
        tool_command="python3 -c \"\nimport ast, sys\ntry:\n    with open('reverse_str.py') as f:\n        src = f.read()\n    tree = ast.parse(src)\n    fns = [n.name for n in ast.walk(tree) if isinstance(n, ast.FunctionDef)]\n    if 'reverse_str' not in fns or 'is_palindrome' not in fns:\n        print(f'Missing functions. Found: {fns}', file=sys.stderr)\n        sys.exit(1)\n    import importlib.util\n    spec = importlib.util.spec_from_file_location('reverse_str', 'reverse_str.py')\n    mod = importlib.util.module_from_spec(spec)\n    spec.loader.exec_module(mod)\n    assert mod.reverse_str('hello') == 'olleh'\n    assert mod.is_palindrome('racecar') is True\n    assert mod.is_palindrome('hello') is False\n    print('pass')\nexcept Exception as e:\n    print(f'Error: {e}', file=sys.stderr)\n    sys.exit(1)\n\"",
        timeout="15s"
    ]

    // ── Fix node: reached when verify exits non-zero ─────────────────────────
    //
    // tool.verify.output is NOT available here (spec §4.10: only set on
    // success). Use $codergen.implement.output instead — it is always set
    // after a box node runs, regardless of the outcome of later nodes.

    fix [
        shape=box,
        prompt="The module failed verification.\n\nPrevious implementation:\n$codergen.implement.output\n\nFix the module. Ensure both reverse_str() and is_palindrome() are present and correct:\n  reverse_str('hello') == 'olleh'\n  is_palindrome('racecar') == True\n  is_palindrome('hello') == False\n\nOverwrite reverse_str.py with the corrected version."
    ]

    done [shape=Msquare, label="Verified"]

    // ── Flow with compound conditions ─────────────────────────────────────────
    //
    // COMPOUND CONDITION on the done edge:
    //   outcome = success        → tool exited 0
    //   AND
    //   tool.verify.output = pass → tool printed "pass" (only set on exit 0)
    //
    // The two clauses are redundant here (exit 0 implies "pass" was printed),
    // but they demonstrate that ANY context key can be used in conditions —
    // not just "outcome". A missing key evaluates to false, so the condition
    // fails safely if the tool didn't run.

    start     -> implement
    implement -> verify

    verify -> done [
        condition="outcome = success && tool.verify.output = pass",
        label="pass"
    ]
    verify -> fix [condition="outcome = fail", label="fail"]

    fix -> verify
}
